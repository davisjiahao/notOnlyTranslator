#!/bin/bash
# pre-push hook - 在推送前验证状态同步

set -e

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[pre-push]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[pre-push]${NC} $1"
}

log_error() {
    echo -e "${RED}[pre-push]${NC} $1"
}

log_info "检查状态文件同步..."

# 检查 board 目录是否有最近的状态更新
BOARD_DIR="${PROJECT_ROOT}/.paperclip/board"
TODAY=$(date +%Y-%m-%d)
WEEK_AGO=$(date -d "7 days ago" +%Y-%m-%d 2>/dev/null || date -v-7d +%Y-%m-%d)

# 查找最新的 board 状态文件
LATEST_BOARD=$(find "${BOARD_DIR}" -name "*.md" -type f -newer "${PROJECT_ROOT}/.git/index" 2>/dev/null | head -1)

if [ -z "$LATEST_BOARD" ]; then
    log_warn "本周没有更新的 board 状态文件"
    log_warn "建议在推送前运行: bash scripts/sync-status.sh"

    # 不阻止推送，但给出警告
    echo ""
    read -p "是否继续推送? (y/N): " -n 1 -r < /dev/tty
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_error "推送已取消"
        exit 1
    fi
else
    log_info "发现更新的 board 文件: $(basename $LATEST_BOARD)"
fi

# 检查是否有未提交的变更
if ! git diff --quiet HEAD 2>/dev/null; then
    log_warn "工作目录有未提交的变更"
    log_warn "建议在推送前提交这些变更"
fi

log_info "状态检查完成！"
exit 0
