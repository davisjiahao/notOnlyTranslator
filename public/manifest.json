{
  "manifest_version": 3,
  "name": "NotOnlyTranslator - 智能分级翻译助手",
  "short_name": "NotOnlyTranslator",
  "version": "0.1.1",
  "description": "智能识别超出你词汇量的单词，只翻译该翻译的内容，让英语学习更自然高效",
  "author": "NotOnlyTranslator Team",
  "homepage_url": "https://github.com/yourusername/notOnlyTranslator",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NotOnlyTranslator"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://*.volces.com/*",
    "https://ark.cn-beijing.volces.com/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*",
    "https://translation.googleapis.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
